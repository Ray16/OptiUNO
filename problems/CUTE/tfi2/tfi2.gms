x.lo('1')=-0;

x.l(j)=1/(ORD(j)+1);

Model m/All/;
m.workspace = 32;
File res/tfi2.res/;
Put res;

options limrow=0,
	limcol=0,
	solprint=off,
	sysout=on,
	nlp=baron,
	reslim=100,
	optca=1e-6,
	optcr=0;
Solve m using nlp minimizing obj;

PUT "modelstatus = ", m.MODELSTAT; PUT /;
loop(j,PUT "x(", j.te(j), ") = ", x.l(j):16:10/);
PUT "obj = ", obj.l:16:10/;
PUT "infeas = ", m.NUMINFES; PUT /;
PUT "nonopt = ", m.NUMNOPT; PUT /;
display x.l, obj.l;
  


